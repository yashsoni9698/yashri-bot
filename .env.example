# ——— Required for public deploy (site login gate) ———
# Anyone with the URL can use the app unless this is set.
APP_PASSWORD=change-me-to-a-strong-password

# Optional: separate cookie-signing secret (defaults to APP_PASSWORD)
AUTH_SECRET=

# ——— AI providers (set at least one) ———
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional override for Memory page unlock (defaults to value in Settings)
MEMORY_PASSWORD=
